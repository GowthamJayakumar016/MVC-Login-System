<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

<div class="container vh-100 d-flex justify-content-center align-items-center">

    <div class="card shadow p-5 text-center" style="width:500px">

        @if (ViewBag.Success == true)
        {
            <h3 class="text-success mb-3">
                Application Submitted Successfully
            </h3>

            <p>Please follow this <b>Application ID</b> for future reference.</p>

            <h4 class="text-primary mb-4">
                @ViewBag.ApplicationNumber
            </h4>

            <a href="/Dashboard/UserDashboard" class="btn btn-primary">
                Go to User Dashboard
            </a>
        }
        else
        {

            <h3 class="mb-4">Credit Evaluation Result</h3>

            <table class="table table-bordered">

                <tr>
                    <th>Name</th>
                    <td>@ViewBag.Name</td>
                </tr>

                <tr>
                    <th>PAN</th>
                    <td>@ViewBag.PAN</td>
                </tr>

                <tr>
                    <th>Credit Score</th>
                    <td>@ViewBag.CreditScore</td>
                </tr>

                <tr>
                    <th>Credit Limit</th>
                    <td>₹ @ViewBag.CreditLimit</td>
                </tr>

            </table>

            <form asp-action="ConfirmLoan" method="post">

                <input type="hidden" name="FirstName" value="@ViewBag.FirstName" />
                <input type="hidden" name="LastName" value="@ViewBag.LastName" />
                <input type="hidden" name="PAN" value="@ViewBag.PAN" />
                <input type="hidden" name="AnnualIncome" value="@ViewBag.AnnualIncome" />
                <input type="hidden" name="CreditScore" value="@ViewBag.CreditScore" />
                <input type="hidden" name="CreditLimit" value="@ViewBag.CreditLimit" />

                <div class="form-check mb-3 text-start">
                    <input class="form-check-input" type="checkbox" required>
                    <label class="form-check-label">
                        I accept the terms and conditions
                    </label>
                </div>

                <button class="btn btn-success w-100 mb-2">
                    Apply Loan
                </button>

                <a href="/Dashboard/UserDashboard" class="btn btn-danger w-100">
                    Reject
                </a>

            </form>

        }

    </div>

</div>