@model List<NewWebApplication.Models.LoanApplication>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

<div class="container mt-5">

    <h2 class="mb-4">Admin Dashboard</h2>

    <!-- Statistics Cards -->

    <div class="row mb-4">

        <div class="col-md-3">
            <div class="card bg-primary text-white text-center">
                <div class="card-body">
                    <h5>Total Applications</h5>
                    <h3>@ViewBag.Total</h3>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card bg-warning text-dark text-center">
                <div class="card-body">
                    <h5>Pending</h5>
                    <h3>@ViewBag.Pending</h3>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card bg-success text-white text-center">
                <div class="card-body">
                    <h5>Approved</h5>
                    <h3>@ViewBag.Approved</h3>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card bg-danger text-white text-center">
                <div class="card-body">
                    <h5>Rejected</h5>
                    <h3>@ViewBag.Rejected</h3>
                </div>
            </div>
        </div>

    </div>

    <!-- Filters -->

    <div class="mb-3">

        <a href="/Admin" class="btn btn-secondary">All</a>
        <a href="/Admin?status=Pending" class="btn btn-warning">Pending</a>
        <a href="/Admin?status=Approved" class="btn btn-success">Approved</a>
        <a href="/Admin?status=Rejected" class="btn btn-danger">Rejected</a>

    </div>

    <!-- Applications Table -->

    <table class="table table-bordered table-striped">

        <thead class="table-dark">

            <tr>
                <th>Application Number</th>
                <th>Name</th>
                <th>PAN</th>
                <th>Action</th>
            </tr>

        </thead>

        <tbody>

            @foreach (var app in Model)
            {
                <tr>

                    <td>@app.ApplicationNumber</td>

                    <td>@app.FirstName @app.LastName</td>

                    <td>@app.PAN</td>

                    <td>
                        <a href="/Admin/Details/@app.Id" class="btn btn-primary btn-sm">
                            View Details
                        </a>
                    </td>

                </tr>
            }

        </tbody>

    </table>

</div>