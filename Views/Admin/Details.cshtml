@model NewWebApplication.Models.LoanApplication

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

<div class="container mt-5">

    <h3 class="mb-4">Loan Application Details</h3>

    <table class="table table-bordered">

        <tr>
            <th>Application Number</th>
            <td>@Model.ApplicationNumber</td>
        </tr>

        <tr>
            <th>Name</th>
            <td>@Model.FirstName @Model.LastName</td>
        </tr>

        <tr>
            <th>PAN</th>
            <td>@Model.PAN</td>
        </tr>

        <tr>
            <th>Annual Income</th>
            <td>₹@Model.AnnualIncome</td>
        </tr>

        <tr>
            <th>Credit Score</th>
            <td>@Model.CreditScore</td>
        </tr>

        <tr>
            <th>Credit Limit</th>
            <td>₹@Model.CreditLimit</td>
        </tr>

        <tr>
            <th>Status</th>
            <td>@Model.Status</td>
        </tr>

    </table>

    @if (Model.Status == "Pending")
    {

        <h4 class="mt-4">Approve Application</h4>

        <form method="post" asp-action="Approve">

            <input type="hidden" name="id" value="@Model.Id" />

            <div class="mb-3">
                <label>Approved By</label>
                <input name="adminName" class="form-control" />
            </div>

            <div class="mb-3">
                <label>Remark</label>
                <input name="remark" class="form-control" />
            </div>

            <button class="btn btn-success">
                Approve
            </button>

        </form>

        <hr />

        <h4>Reject Application</h4>

        <form method="post" asp-action="Reject">

            <input type="hidden" name="id" value="@Model.Id" />

            <div class="mb-3">
                <label>Rejected By</label>
                <input name="adminName" class="form-control" />
            </div>

            <div class="mb-3">
                <label>Reason</label>
                <input name="reason" class="form-control" />
            </div>

            <button class="btn btn-danger">
                Reject
            </button>

        </form>

    }

    <div class="mt-4">

        <div class="mt-4">

            <a asp-controller="Admin"
               asp-action="Index"
               class="btn btn-secondary">
                Back to Admin Dashboard
            </a>

        </div>

    </div>

</div>