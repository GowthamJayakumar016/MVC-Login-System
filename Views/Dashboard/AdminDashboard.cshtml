@model List<NewWebApplication.Models.LoanApplication>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

<style>
    .violet-btn {
        background-color: #6f42c1;
        color: white;
    }

        .violet-btn:hover {
            background-color: #5a32a3;
            color: white;
        }
</style>

<div class="container mt-5">

    <h2 class="mb-4">Admin Dashboard</h2>

    <!-- Filter Buttons -->

    <div class="mb-4">

        <a asp-controller="Admin"
           asp-action="Index"
           class="btn violet-btn me-2">
            All
        </a>

        <a asp-controller="Admin"
           asp-action="Index"
           asp-route-status="Pending"
           class="btn violet-btn me-2">
            Pending
        </a>

        <a asp-controller="Admin"
           asp-action="Index"
           asp-route-status="Approved"
           class="btn violet-btn me-2">
            Approved
        </a>

        <a asp-controller="Admin"
           asp-action="Index"
           asp-route-status="Rejected"
           class="btn violet-btn">
            Rejected
        </a>

    </div>

    <!-- Applications Table -->

    <table class="table table-bordered table-hover">

        <thead style="background-color:#6f42c1;color:white">

            <tr>
                <th>Application Number</th>
                <th>Name</th>
                <th>PAN</th>
                <th>Details</th>
            </tr>

        </thead>

        <tbody>

            @foreach (var app in Model)
            {
                <tr>

                    <td>@app.ApplicationNumber</td>

                    <td>@app.FirstName @app.LastName</td>

                    <td>@app.PAN</td>

                    <td>

                        <a asp-controller="Admin"
                           asp-action="Details"
                           asp-route-id="@app.Id"
                           class="btn violet-btn btn-sm">
                            View Details
                        </a>

                    </td>

                </tr>
            }

        </tbody>

    </table>

</div>